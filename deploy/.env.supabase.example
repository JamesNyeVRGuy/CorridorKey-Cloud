# Supabase Self-Hosted Configuration
# Copy to .env.supabase and fill in the values.
# Generate secrets with: openssl rand -hex 32

# ─── Database ────────────────────────────────────────────────────────

POSTGRES_PASSWORD=change_me_use_openssl_rand
POSTGRES_DB=corridorkey
POSTGRES_PORT=54322

# ─── Authentication (GoTrue) ─────────────────────────────────────────

# JWT secret — MUST match what CorridorKey web server uses to validate tokens
JWT_SECRET=change_me_use_openssl_rand_hex_32
JWT_EXPIRY=3600

# Site URL — where users are redirected after auth actions
SITE_URL=http://localhost:3000

# Auto-confirm email on signup (true = no email verification needed)
# Set to false once SMTP is configured
MAILER_AUTOCONFIRM=true

# Disable public signup (users can only join via invite links)
DISABLE_SIGNUP=false

# ─── SMTP (Postmark — optional, for email verification/invites) ──────

# Sign up at https://postmarkapp.com (100 emails/month free)
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=your-postmark-server-api-token
# SMTP_PASS=your-postmark-server-api-token
# SMTP_ADMIN_EMAIL=noreply@yourdomain.com
# SMTP_SENDER_NAME=CorridorKey

# ─── API Keys ────────────────────────────────────────────────────────

# Generate these using the Supabase JWT tool or manually:
# https://supabase.com/docs/guides/self-hosting#api-keys
#
# ANON_KEY is the public key (safe to expose in frontend)
# SERVICE_ROLE_KEY is the admin key (never expose to clients)
ANON_KEY=
SERVICE_ROLE_KEY=

# ─── URLs and Ports ──────────────────────────────────────────────────

API_EXTERNAL_URL=http://localhost:54321
GOTRUE_PORT=54324
POSTGREST_PORT=54321
STUDIO_PORT=54323

# ─── CorridorKey Web Server Connection ────────────────────────────────

# Set these in your main .env or docker-compose environment:
# CK_SUPABASE_URL=http://localhost:54321
# CK_SUPABASE_ANON_KEY=<your anon key>
# CK_SUPABASE_SERVICE_KEY=<your service role key>
# CK_JWT_SECRET=<same as JWT_SECRET above>
# CK_AUTH_ENABLED=true
