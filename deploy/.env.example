# CorridorKey Cloud Platform — Environment Configuration
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Generate secrets:
#   openssl rand -hex 32
#
# IMPORTANT: Do NOT use quotes around values. Do NOT add trailing spaces.
# Windows users: ensure this file uses Unix line endings (LF, not CRLF).

# ═══════════════════════════════════════════════════════════════════════
# SECRETS — Generate unique values for each deployment
# ═══════════════════════════════════════════════════════════════════════

# Database password (used by all Supabase services)
POSTGRES_PASSWORD=change_me_use_openssl_rand_hex_32

# JWT secret — shared between GoTrue (signs tokens) and CK web (validates)
# MUST be the same value in both. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_use_openssl_rand_hex_32

# Supabase API keys — generate at https://supabase.com/docs/guides/self-hosting#api-keys
# ANON_KEY: public key (safe for frontend)
# SERVICE_ROLE_KEY: admin key (server-only, never expose to clients)
ANON_KEY=
SERVICE_ROLE_KEY=

# ═══════════════════════════════════════════════════════════════════════
# CORRIDORKEY WEB SERVER
# ═══════════════════════════════════════════════════════════════════════

# Port the WebUI listens on
CK_PORT=3000

# Enable multi-user auth (requires Supabase stack running)
# Set to false for single-user local mode (no login required)
CK_AUTH_ENABLED=false

# JWT secret for token validation — MUST match JWT_SECRET above
CK_JWT_SECRET=change_me_same_as_jwt_secret_above

# GoTrue auth service URL (inside Docker network)
CK_GOTRUE_INTERNAL_URL=http://supabase-auth:9999

# GoTrue external URL (for browser redirects — only needed if not proxied)
# CK_GOTRUE_URL=http://localhost:54324

# Supabase service role key (for admin user creation via create-admin.sh)
CK_SUPABASE_SERVICE_KEY=same_as_service_role_key_above

# Postgres connections — both use supabase_admin (the Supabase image's superuser).
# Replace "change_me" with your POSTGRES_PASSWORD value.
# NOTE: the password is embedded in the URL, not substituted — copy it manually.
CK_DATABASE_URL=postgresql://supabase_admin:change_me@supabase-db:5432/corridorkey
CK_MIGRATION_URL=postgresql://supabase_admin:change_me@supabase-db:5432/corridorkey

# Path to Projects directory (clips, outputs)
CK_PROJECTS_DIR=./Projects

# Path to model weights
CK_WEIGHTS_DIR=./weights

# GPU visibility — "all", "0", "1", or "0,1"
NVIDIA_VISIBLE_DEVICES=all

# ═══════════════════════════════════════════════════════════════════════
# REDIS (optional — for multi-instance deployment)
# ═══════════════════════════════════════════════════════════════════════

# When set, node registry + job queue state is stored in Redis instead of
# in-memory. Required for running multiple web replicas behind a load
# balancer. Leave empty for single-instance deployments.
CK_REDIS_URL=redis://redis:6379/0

# ═══════════════════════════════════════════════════════════════════════
# SUPABASE SERVICES
# ═══════════════════════════════════════════════════════════════════════

# Database
POSTGRES_DB=corridorkey
POSTGRES_PORT=54322

# GoTrue auth
GOTRUE_JWT_SECRET=change_me_same_as_jwt_secret
JWT_EXPIRY=3600
SITE_URL=http://localhost:3000
MAILER_AUTOCONFIRM=true
DISABLE_SIGNUP=true
GOTRUE_PORT=54324

# PostgREST (not actively used by CK, but part of Supabase stack)
POSTGREST_PORT=54321
API_EXTERNAL_URL=http://localhost:54321

# Supabase Studio (database admin UI)
STUDIO_PORT=54323

# ═══════════════════════════════════════════════════════════════════════
# SMTP (Docker-mailserver + Roundcube on corridorkey.cloud)
# ═══════════════════════════════════════════════════════════════════════

SMTP_HOST=smtp.corridorkey.cloud
SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
SMTP_ADMIN_EMAIL=noreply@corridorkey.cloud
SMTP_SENDER_NAME=CorridorKey

# ═══════════════════════════════════════════════════════════════════════
# MONITORING (optional)
# ═══════════════════════════════════════════════════════════════════════

# Prometheus metrics at /metrics
CK_METRICS_ENABLED=false

# Secure /metrics with a bearer token (optional — leave empty for open access)
# When set, Prometheus must send: authorization: {type: Bearer, credentials: <token>}
# CK_METRICS_TOKEN=

# Structured JSON logging for Loki ingestion
# CK_LOG_FORMAT=text

# Sentry error tracking
# CK_SENTRY_DSN=
# CK_ENVIRONMENT=production

# API docs access (default: public when auth off, protected when on)
# CK_DOCS_PUBLIC=true

# ═══════════════════════════════════════════════════════════════════════
# S3 STORAGE (optional — default is local filesystem)
# ═══════════════════════════════════════════════════════════════════════

# CK_STORAGE_BACKEND=local
# CK_S3_BUCKET=
# CK_S3_PREFIX=
# CK_S3_ENDPOINT_URL=
# CK_S3_REGION=us-east-1
# CK_S3_ACCESS_KEY_ID=
# CK_S3_SECRET_ACCESS_KEY=

# ═══════════════════════════════════════════════════════════════════════
# RENDER FARM (nodes)
# ═══════════════════════════════════════════════════════════════════════

# Legacy shared secret for node auth (prefer per-node tokens instead)
CK_AUTH_TOKEN=

# Node agent settings (only used by docker-compose.node.yml)
CK_MAIN_URL=http://192.168.1.100:3000
CK_NODE_NAME=my-render-node
CK_NODE_GPUS=auto
CK_SHARED_STORAGE=

# ═══════════════════════════════════════════════════════════════════════
# TLS / HTTPS (docker-compose.caddy.yml)
# ═══════════════════════════════════════════════════════════════════════

# CK_DOMAIN=corridorkey.yourdomain.com
