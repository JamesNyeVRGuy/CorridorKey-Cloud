# CorridorKey Docker Configuration
# Copy this file to .env and edit the values below.

# ─── Main Server (docker-compose.web.yml) ───────────────────────────

# Port the WebUI listens on
CK_PORT=3000

# Path to your Projects directory (clips, outputs, etc.)
CK_PROJECTS_DIR=./Projects

# Path to model weights directory. Should contain subdirectories:
#   corridorkey/  — CorridorKey_v1.0.pth
#   gvm/          — vae/, unet/, scheduler/
#   videomama/    — VideoMaMa checkpoint files
# Leave as default to use ./weights/ next to this file.
CK_WEIGHTS_DIR=./weights

# GPU visibility — "all", "0", "1", or "0,1" for multi-GPU
NVIDIA_VISIBLE_DEVICES=all

# ─── Monitoring & Observability ────────────────────────────────────────

# Sentry DSN for error tracking (optional)
# CK_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# CK_ENVIRONMENT=production

# Prometheus metrics — set to true to enable /metrics endpoint (CRKY-27)
CK_METRICS_ENABLED=false

# Structured JSON logging — set to "json" for Loki/Promtail ingestion (CRKY-50)
# Default "text" for human-readable logs.
# CK_LOG_FORMAT=text

# ─── API Documentation ────────────────────────────────────────────────

# Public API docs at /docs and /redoc (CRKY-32)
# Default: public when auth disabled, protected when auth enabled.
# Set explicitly to override.
# CK_DOCS_PUBLIC=true

# ─── S3 Storage Backend (optional) ────────────────────────────────────

# Default "local" uses the filesystem. Set to "s3" for S3-compatible storage.
# CK_STORAGE_BACKEND=local
# CK_S3_BUCKET=my-corridorkey-bucket
# CK_S3_PREFIX=                          # key prefix (optional)
# CK_S3_ENDPOINT_URL=                    # for MinIO, B2, R2 (optional)
# CK_S3_REGION=us-east-1
# CK_S3_ACCESS_KEY_ID=
# CK_S3_SECRET_ACCESS_KEY=

# ─── TLS / HTTPS (docker-compose.caddy.yml) ──────────────────────────

# Domain name for automatic Let's Encrypt HTTPS
# CK_DOMAIN=corridorkey.yourdomain.com

# ─── Cloud Platform (optional — enable for multi-user auth) ──────────

# Set CK_AUTH_ENABLED=true to require login. Default false (single-user mode).
CK_AUTH_ENABLED=false

# Supabase connection (required when CK_AUTH_ENABLED=true)
# CK_SUPABASE_URL=http://localhost:54321
# CK_SUPABASE_ANON_KEY=your-anon-key
# CK_SUPABASE_SERVICE_KEY=your-service-role-key
# CK_JWT_SECRET=same-as-supabase-jwt-secret

# Direct Postgres connection for server state (settings, invites, job history).
# When CK_AUTH_ENABLED=true and this is set, state is stored in Postgres
# instead of the JSON file. Uses the same Supabase Postgres instance.
# CK_DATABASE_URL=postgresql://postgres:your-password@localhost:54322/corridorkey

# ─── Shared (both server and nodes) ──────────────────────────────────

# Shared secret for node authentication. Set the same value on the
# server and all nodes. Leave empty to allow any machine to connect.
CK_AUTH_TOKEN=
# CK_AUTH_TOKEN=my-secret-token

# ─── Node Agent (docker-compose.node.yml) ────────────────────────────

# Main server URL (REQUIRED for nodes)
CK_MAIN_URL=http://192.168.1.100:3000

# Display name for this node in the Render Farm UI
CK_NODE_NAME=my-render-node

# Which GPUs to use — "auto" detects all, or "0", "0,1" for specific
CK_NODE_GPUS=auto

# Shared storage path. If both main and node can access the same
# Projects directory (NFS/SMB mount), set this to skip HTTP file
# transfer. Leave empty to transfer files over the network.
CK_SHARED_STORAGE=
# CK_SHARED_STORAGE=/app/Projects
