# CorridorKey Node Configuration
# Copy this file to node.env and fill in the values.

# Server URL (required) — the main CorridorKey Cloud instance
CK_MAIN_URL=https://corridorkey.cloud

# Auth token (required) — generate one from the Nodes page in the web UI
CK_AUTH_TOKEN=

# Node name — identifies this machine in the dashboard
CK_NODE_NAME=my-node

# GPU selection: "auto" detects all GPUs, or specify indices like "0" or "0,1"
CK_NODE_GPUS=auto

# Job types to accept (empty = all): inference, gvm_alpha, videomama_alpha
CK_NODE_ACCEPTED_TYPES=

# Pre-load model into VRAM on startup (true/false)
CK_NODE_PREWARM=true
