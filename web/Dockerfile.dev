FROM node:20-slim
WORKDIR /src

ARG CKWEB_FILE_BASE=""
ENV CKWEB_FILE_BASE=${CKWEB_FILE_BASE}
ENV HOST=0.0.0.0
ENV PORT=5173
ENV CHOKIDAR_USEPOLLING=true

COPY web/frontend/package.json web/frontend/package-lock.json* ./
RUN npm ci --no-audit --no-fund

# fallback copy; compose will typically mount local source over /src
COPY web/frontend/ .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]